{
  "name": "celluphile",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:clean": "jest --noStackTrace --json --outputFile=jest-results.json --onlyFailures",
    "test:watch": "jest --watch",
    "test:all": "npm run test && npm run e2e:headless",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cy:run": "NODE_ENV=test start-server-and-test 'npm run dev > /dev/null 2>&1' http://localhost:3000",
    "e2e": "NODE_ENV=test start-server-and-test dev http://localhost:3000 \"cypress open --e2e\"",
    "e2e:headless-verbose": "NODE_ENV=test start-server-and-test dev http://localhost:3000 \"cypress run --e2e\"",
    "e2e:headless": "NODE_ENV=test start-server-and-test 'npm run dev > /dev/null 2>&1' http://localhost:3000 'cypress run --e2e'"
  },
  "dependencies": {
    "@auth/mongodb-adapter": "^3.11.1",
    "@heroicons/react": "^2.2.0",
    "bcryptjs": "^3.0.3",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "mongoose": "^9.0.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.30",
    "postcss": "^8.5.10",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sonner": "^2.0.7",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/web-push": "^3.6.4",
    "baseline-browser-mapping": "^2.10.22",
    "cypress": "^15.12.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^4.1.17",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
